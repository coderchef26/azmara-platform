{
  "name": "@azmr/db",
  "version": "0.0.1",
  "description": "Secure SQLite persistence adapter \u00e2\u20ac\u201d parameterised queries, path containment, tamper-evident audit log",
  "type": "module",
  "license": "MIT",
  "author": "Alshafaraz Gazi <alshafaraz.gazi@gmail.com>",
  "homepage": "https://docs.azmara.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coderchef26/azmara-platform.git",
    "directory": "packages/db"
  },
  "keywords": ["sqlite", "database", "local-first", "offline", "reactive", "secure", "azmara"],
  "engines": {
    "node": ">=18.0.0"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@azmr/security": "workspace:*",
    "better-sqlite3": "^11.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
