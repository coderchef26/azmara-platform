{
  "name": "@azmara/cli",
  "version": "0.0.1",
  "private": true,
  "description": "Azmara CLI — scaffold, query, and manage your Azmara platform",
  "type": "module",
  "bin": {
    "azmara": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@azmara/core": "workspace:*",
    "@azmara/db": "workspace:*",
    "@azmara/security": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
