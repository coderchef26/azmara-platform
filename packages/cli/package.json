{
  "name": "@azmr/cli",
  "version": "0.0.1",
  "description": "Azmara CLI \u00e2\u20ac\u201d scaffold apps, query local SQLite databases, manage your platform",
  "type": "module",
  "license": "MIT",
  "author": "Alshafaraz Gazi <alshafaraz.gazi@gmail.com>",
  "homepage": "https://docs.azmara.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coderchef26/azmara-platform.git",
    "directory": "packages/cli"
  },
  "keywords": ["cli", "scaffold", "sqlite", "developer-tools", "azmara"],
  "engines": {
    "node": ">=18.0.0"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "bin": {
    "azmara": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@azmr/core": "workspace:*",
    "@azmr/db": "workspace:*",
    "@azmr/security": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
