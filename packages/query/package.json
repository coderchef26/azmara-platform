{
  "name": "@azmara/query",
  "version": "0.0.1",
  "description": "Chainable, data-first query engine over reactive data sources",
  "type": "module",
  "license": "MIT",
  "author": "Alshafaraz Gazi <alshafaraz.gazi@gmail.com>",
  "homepage": "https://docs.azmara.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coderchef26/azmara-platform.git",
    "directory": "packages/query"
  },
  "keywords": ["query", "filter", "sort", "data", "reactive", "typesafe", "azmara"],
  "engines": { "node": ">=18.0.0" },
  "files": ["dist", "README.md", "LICENSE"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@azmara/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
