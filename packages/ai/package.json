{
  "name": "@azmr/ai",
  "version": "0.0.1",
  "description": "AI auto-fix system with isolated-vm sandboxing — safe code execution and analysis",
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist"],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@azmr/security": "workspace:*"
  },
  "optionalDependencies": {
    "isolated-vm": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  },
  "notes": {
    "isolated-vm": "Requires node-gyp native compilation. On Windows: install Visual Studio Build Tools + Python. See: https://github.com/nicolo-ribaudo/isolated-vm"
  }
}
