{
  "name": "@azmr/playground",
  "version": "0.0.1",
  "private": true,
  "description": "Playground app — develop and test Azmara platform packages",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "web": "vite",
    "build": "tsup src/index.ts --format esm --clean",
    "check-types": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@azmr/core": "workspace:*",
    "@azmr/db": "workspace:*",
    "@azmr/query": "workspace:*",
    "@azmr/security": "workspace:*",
    "@azmr/ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.9"
  }
}
