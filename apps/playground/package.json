{
  "name": "@azmara/playground",
  "version": "0.0.1",
  "private": true,
  "description": "Playground app — develop and test Azmara platform packages",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --clean",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@azmara/core": "workspace:*",
    "@azmara/db": "workspace:*",
    "@azmara/query": "workspace:*",
    "@azmara/security": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
