# Azmara Platform — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# AI Provider (required for @azmara/ai)
OPENAI_API_KEY=

# Audit log output path (default: .azmara/audit.log)
AZMARA_AUDIT_LOG=.azmara/audit.log

# Database directory (default: .azmara/db)
AZMARA_DB_PATH=.azmara/db/azmara.db

# Encryption key for sensitive DB columns — generate with: openssl rand -hex 32
AZMARA_ENCRYPTION_KEY=
